{
  "name": "@wmfs/cardscript-schema",
  "description": "Contains a JSON Schema for Cardscript, along with a validation utility.",
  "version": "0.0.0-semantically-released",
  "author": "West Midlands Fire Service",
  "keywords": [
    "tymly",
    "cardscript"
  ],
  "main": "./lib/index.js",
  "dependencies": {
    "dottie": "2.0.6",
    "jsonschema": "1.4.1",
    "lodash": "4.17.21"
  },
  "devDependencies": {
    "chai": "4.5.0",
    "codecov": "3.8.3",
    "conventional-changelog-conventionalcommits": "10.2.1",
    "cz-conventional-changelog": "3.3.0",
    "mocha": "11.7.6",
    "nyc": "18.0.0",
    "semantic-release": "25.0.8",
    "standard": "17.1.2",
    "@semantic-release/changelog": "7.0.0",
    "@semantic-release/release-notes-generator": "14.1.1",
    "@semantic-release/git": "11.0.0",
    "@wmfs/cardscript-examples": "1.23.0"
  },
  "scripts": {
    "lint": "standard",
    "test": "nyc mocha",
    "coverage": "nyc report --reporter=text-lcov > coverage.lcov && codecov",
    "semantic-release": "semantic-release"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wmfs/cardscript-schema.git"
  },
  "bugs": {
    "url": "https://github.com/wmfs/cardscript-schema/issues"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
